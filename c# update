    public class InvalidSessionDurationException : Exception
    {
        public InvalidSessionDurationException(int attemptedValue)
            : base($"Duration must be between 15 and 180 minutes. Checked value: {attemptedValue}.")
        {
        }
    }

    public abstract class Membership
    {
        public string MembershipId { get; set; }
        public string MemberName { get; set; }
        public DateTime StartDate { get; set; }

        protected Membership(string membershipId, string memberName, DateTime startDate)
        {
            MembershipId = membershipId;
            MemberName = memberName;
            StartDate = startDate;
        }

        public abstract decimal CalculateMonthlyFee();
        public virtual string GetPerks() => "No extra benefits.";

        protected int MonthsEnrolled()
        {
            var now = DateTime.Now;
            int months = (now.Year - StartDate.Year) * 12 + (now.Month - StartDate.Month);
            return months < 0 ? 0 : months;
        }

        public abstract string TypeTag();
    }

    public class StandardMembership : Membership
    {
        public decimal BaseRate { get; set; }
        public StandardMembership(string membershipId, string memberName, DateTime startDate, decimal baseRate)
            : base(membershipId, memberName, startDate) { BaseRate = baseRate; }

        public override decimal CalculateMonthlyFee() => BaseRate;
        public override string GetPerks() => "Standard gym access.";
        public override string TypeTag() => "Standard";
    }

    public class PremiumMembership : Membership
    {
        public decimal BaseRate { get; set; }
        public decimal TrainingCreditValue { get; set; }
        public decimal LoyaltyDiscount { get; set; }

        public PremiumMembership(string membershipId, string memberName, DateTime startDate,
            decimal baseRate, decimal trainingCreditValue, decimal loyaltyDiscount)
            : base(membershipId, memberName, startDate)
        {
            BaseRate = baseRate;
            TrainingCreditValue = trainingCreditValue;
            LoyaltyDiscount = loyaltyDiscount;
        }

        public override decimal CalculateMonthlyFee()
        {
            decimal fee = BaseRate + TrainingCreditValue;
            if (MonthsEnrolled() >= 6) fee -= LoyaltyDiscount;
            return fee;
        }

        public override string GetPerks()
        {
            string loyalty = MonthsEnrolled() >= 6 ? " + Loyalty discount active" : "";
            return $"1 Personal training credit included{loyalty}.";
        }

        public override string TypeTag() => "Premium";
    }

    public class StudentMembership : Membership
    {
        public decimal BaseRate { get; set; }
        public string StudentId { get; set; }

        public StudentMembership(string membershipId, string memberName, DateTime startDate, decimal baseRate, string studentId)
            : base(membershipId, memberName, startDate) { BaseRate = baseRate; StudentId = studentId; }

        private bool HasValidStudentId() => !string.IsNullOrWhiteSpace(StudentId);
        public override decimal CalculateMonthlyFee() => HasValidStudentId() ? BaseRate * 0.80m : BaseRate;
        public override string GetPerks() => HasValidStudentId() ? "Student discount applied (20% off)." : "No Student ID added - Standard rate applied.";
        public override string TypeTag() => "Student";
    }

