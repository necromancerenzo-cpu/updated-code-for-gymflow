            while (true)
            {
                Console.Clear();
                DrawHeader();
                Console.ForegroundColor = ConsoleColor.Cyan;
                Console.WriteLine("  [1] Register New Member          [5] View Billing Reports");
                Console.WriteLine("  [2] Book Training Session        [6] View Active Trainers");
