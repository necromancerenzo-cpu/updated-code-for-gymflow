            }
            PressAnyKey();
        }

        private static void RunViewBilling()
        {
            Console.WriteLine(">>> MONTHLY BILLING SUMMARY\n");
            if (!Tracker.Members.Any()) Console.WriteLine("No registered members on record.");
            foreach (var m in Tracker.Members)
            {
                Console.WriteLine($" Client: {m.Name,-18} ({m.Membership.TypeTag()} Plan) -> Monthly Fee: {m.Membership.CalculateMonthlyFee():C}");
                Console.ForegroundColor = ConsoleColor.DarkGray;
                Console.WriteLine($"   * Note: {m.Membership.GetPerks()}");
                Console.ResetColor();
            }
            PressAnyKey();
        }

        private static void RunViewTrainers()
        {
            Console.WriteLine(">>> REGISTERED FITNESS TRAINERS\n");
            foreach (var t in Tracker.Trainers)
            {
                Console.WriteLine($" ID: {t.TrainerId,-10} | Name: {t.Name,-20} | Specialty: {t.Specialization,-22} | Rate: {t.HourlyRate:C}/hour (Started: {t.StartYear})");
            }
            PressAnyKey();
        }

        private static void RunViewPricingGrid()
        {
            Console.WriteLine(">>> MASTER MEMBERSHIP PRICING CATALOG\n");
            Console.WriteLine($"Standard Plan : {MembershipPricing.StandardRate:C}/month");
            
            decimal premiumFull = MembershipPricing.PremiumBaseRate + MembershipPricing.PremiumTrainingCredit;
            decimal premiumAfterLoyalty = premiumFull - MembershipPricing.PremiumLoyaltyDiscount;
            Console.WriteLine($"Premium Plan  : {premiumFull:C}/month (Includes {MembershipPricing.PremiumTrainingCredit:C} package credits)");
            Console.WriteLine($"   -> Loyalty Rate   : {premiumAfterLoyalty:C}/month (Applied automatically starting month 6)");

            decimal studentDiscounted = MembershipPricing.StudentBaseRate * MembershipPricing.StudentDiscountMultiplier;
            Console.WriteLine($"Student Plan  : {studentDiscounted:C}/month (Requires valid Student ID code entry)");
            PressAnyKey();
        }
    }
