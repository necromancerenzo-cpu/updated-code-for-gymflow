            Console.WriteLine("---------------------------------------------------------------------");
            Console.ResetColor();
        }

        private static void PressAnyKey()
        {
            Console.WriteLine();
            Console.ForegroundColor = ConsoleColor.DarkYellow;
            Console.Write("Press any key to go back to the main menu...");
            Console.ResetColor();
            Console.ReadKey();
        }

        private static void ProcessCommand(string choice)
        {
            Console.Clear();
            DrawHeader();

            switch (choice)
            {
                case "1":
                    RunAddMember();
                    break;
                case "2":
                    RunBookSession();
                    break;
                case "3":
                    RunCancelSession();
                    break;
                case "4":
                    RunViewRecords();
                    break;
                case "5":
                    RunViewBilling();
                    break;
                case "6":
                    RunViewTrainers();
                    break;
                case "7":
