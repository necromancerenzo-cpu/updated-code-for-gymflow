                    Console.WriteLine("Invalid selection. Please type a number between 1 and 8.");
                    Console.ResetColor();
                    PressAnyKey();
                    break;
            }
        }

        private static void RunAddMember()
        {
            Console.WriteLine(">>> MEMBER REGISTRATION\n");
            Console.Write("Enter Member ID: ");
            string memberId = Console.ReadLine();
            Console.Write("Enter Full Name: ");
            string name = Console.ReadLine();
            Console.Write("Enter Contact Number: ");
            string contact = Console.ReadLine();
            Console.Write("Enter Gender Identity (or leave blank): ");
            string genderIdentity = Console.ReadLine();

            if (string.IsNullOrWhiteSpace(memberId) || string.IsNullOrWhiteSpace(name))
            {
                Console.ForegroundColor = ConsoleColor.Red;
                Console.WriteLine("\n[FAILED] Member ID and Name fields cannot be left empty.");
                Console.ResetColor();
                PressAnyKey();
                return;
            }

            Console.WriteLine("\nSelect Membership Plan:");
            Console.WriteLine(" [1] Standard Plan");
            Console.WriteLine(" [2] Premium Plan");
            Console.WriteLine(" [3] Student Plan");
            Console.Write("Choice: ");
            string tierChoice = Console.ReadLine();

            string membershipId = "M-" + Guid.NewGuid().ToString("N").Substring(0, 6);
            DateTime startDate = DateTime.Now;
            Membership membership;

            if (tierChoice == "2")
            {
                membership = new PremiumMembership(membershipId, name, startDate,
                    MembershipPricing.PremiumBaseRate, MembershipPricing.PremiumTrainingCredit,
                    MembershipPricing.PremiumLoyaltyDiscount);
            }
            else if (tierChoice == "3")
            {
                Console.Write("Enter Student ID Card Number: ");
                string studentId = Console.ReadLine();
                membership = new StudentMembership(membershipId, name, startDate, MembershipPricing.StudentBaseRate, studentId);
            }
            else
            {
                membership = new StandardMembership(membershipId, name, startDate, MembershipPricing.StandardRate);
            }

            Tracker.AddMember(new Member(memberId, name, contact, genderIdentity, membership));
            Console.ForegroundColor = ConsoleColor.Green;
            Console.WriteLine($"\n[SUCCESS] Successfully registered {name} into the system.");
            Console.ResetColor();
            PressAnyKey();
        }

        private static void RunBookSession()
        {
            Console.WriteLine(">>> BOOK TRAINING SESSION\n");
            if (!Tracker.Members.Any())
            {
                Console.ForegroundColor = ConsoleColor.Red;
                Console.WriteLine("[FAILED] No registered members found. Please add a member first.");
                Console.ResetColor();
                PressAnyKey();
                return;
            }

            Console.WriteLine("Select Member:");
            for (int i = 0; i < Tracker.Members.Count; i++)
            {
                Console.WriteLine($" [{i}] ID: {Tracker.Members[i].MemberId} - {Tracker.Members[i].Name}");
            }
            Console.Write("Enter member row number: ");
            if (!int.TryParse(Console.ReadLine(), out int memIdx) || memIdx < 0 || memIdx >= Tracker.Members.Count)
            {
                Console.ForegroundColor = ConsoleColor.Red;
                Console.WriteLine("[ERROR] Invalid selection number.");
                Console.ResetColor();
                PressAnyKey();
                return;
            }

            Console.WriteLine("\nSelect Trainer:");
            for (int i = 0; i < Tracker.Trainers.Count; i++)
            {
                Console.WriteLine($" [{i}] ID: {Tracker.Trainers[i].TrainerId} | {Tracker.Trainers[i].Name} ({Tracker.Trainers[i].Specialization})");
            }
            Console.Write("Enter trainer row number: ");
            if (!int.TryParse(Console.ReadLine(), out int trnIdx) || trnIdx < 0 || trnIdx >= Tracker.Trainers.Count)
            {
                Console.ForegroundColor = ConsoleColor.Red;
                Console.WriteLine("[ERROR] Invalid selection number.");
                Console.ResetColor();
                PressAnyKey();
                return;
            }

            Console.Write("\nEnter Date (yyyy-MM-dd, or leave blank for today): ");
            string dateStr = Console.ReadLine();
            DateTime sessionDate = string.IsNullOrWhiteSpace(dateStr) ? DateTime.Today : DateTime.Parse(dateStr);

            Console.Write("Enter Duration (in minutes): ");
            int.TryParse(Console.ReadLine(), out int duration);

            Console.WriteLine("\nSelect Priority Level:");
            Console.WriteLine(" [0] Low   [1] Normal   [2] High");
            Console.Write("Choice: ");
            string priStr = Console.ReadLine();
            SessionPriority priority = priStr == "0" ? SessionPriority.Low : priStr == "2" ? SessionPriority.High : SessionPriority.Normal;

            var member = Tracker.Members[memIdx];
            var trainer = Tracker.Trainers[trnIdx];

            if (Tracker.TryBookSession(member, trainer, sessionDate, duration, priority, out string errorMessage))
            {
                Console.ForegroundColor = ConsoleColor.Green;
                Console.WriteLine($"\n[SUCCESS] Session successfully booked.");
                Console.ResetColor();
            }
            else
            {
                Console.ForegroundColor = ConsoleColor.Red;
                Console.WriteLine($"\n[REJECTED] Booking failed: {errorMessage}");
                Console.ResetColor();
            }
            PressAnyKey();
        }

        private static void RunCancelSession()
        {
            Console.WriteLine(">>> CANCEL SCHEDULED SESSION\n");

            var activeSessions = Tracker.Sessions.Where(s => s.Status != "Cancelled").ToList();

            if (!activeSessions.Any())
            {
                Console.ForegroundColor = ConsoleColor.Yellow;
                Console.WriteLine("There are currently no active booked sessions to cancel.");
                Console.ResetColor();
                PressAnyKey();
                return;
            }

            Console.ForegroundColor = ConsoleColor.Cyan;
            Console.WriteLine("--- ACTIVE BOOKED SESSION LIST ---");
            Console.ResetColor();
            foreach (var s in activeSessions)
            {
                Console.WriteLine($" ID: {s.SessionId} | {s.Date:yyyy-MM-dd} | Client: {s.Member.Name} with Trainer: {s.Trainer.Name} ({s.DurationMinutes} mins)");
            }
            Console.WriteLine();

            Console.ForegroundColor = ConsoleColor.Cyan;
            Console.WriteLine("--- SESSIONS BY PRIORITY LEVEL ---");
            Console.ResetColor();
            var groupedSessions = activeSessions.GroupBy(s => s.Priority).OrderByDescending(g => g.Key);
            foreach (var group in groupedSessions)
            {
                Console.ForegroundColor = group.Key == SessionPriority.High ? ConsoleColor.Red :
                                      group.Key == SessionPriority.Normal ? ConsoleColor.Yellow : ConsoleColor.Gray;
                Console.WriteLine($" [{group.Key} Priority Group]");
                Console.ResetColor();

                foreach (var s in group)
                {
                    Console.WriteLine($"   * ID: {s.SessionId} -> Client: {s.Member.Name} | Trainer: {s.Trainer.Name}");
                }
            }
            DrawDivider();

            Console.Write("Enter the exact Session ID you wish to cancel (e.g., S-000001): ");
            string targetId = Console.ReadLine().Trim();

            if (Tracker.TryCancelSession(targetId, out string message))
            {
                Console.ForegroundColor = ConsoleColor.Green;
                Console.WriteLine($"\n[SUCCESS] {message}");
            }
            else
            {
                Console.ForegroundColor = ConsoleColor.Red;
                Console.WriteLine($"\n[FAILED] {message}");
            }
            Console.ResetColor();
            PressAnyKey();
        }

