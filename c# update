    public class GymTracker
    {
        private const string MembersFile = "members.txt";
        private const string SessionsFile = "sessions.txt";
        private int _sessionCounter = 0;
        
        private Dictionary<int, int> _yearlyTrainerCounters = new Dictionary<int, int>();

        public List<Member> Members { get; } = new List<Member>();
        public List<Trainer> Trainers { get; } = new List<Trainer>();
        public List<TrainingSession> Sessions { get; } = new List<TrainingSession>();

        public void AddMember(Member member) => Members.Add(member);

        public Trainer GetOrAddTrainer(string name, string specialization, decimal hourlyRate, int startYear, string existingId = null)
        {
            var existing = Trainers.FirstOrDefault(t => t.Name.Equals(name, StringComparison.OrdinalIgnoreCase));
            if (existing != null) return existing;

            string trainerId = existingId;
            if (string.IsNullOrEmpty(trainerId))
            {
                if (!_yearlyTrainerCounters.ContainsKey(startYear))
                {
                    _yearlyTrainerCounters[startYear] = 0;
                }
                _yearlyTrainerCounters[startYear]++;
                
                string shortYear = startYear.ToString().Substring(1); 
                trainerId = $"{shortYear}-{_yearlyTrainerCounters[startYear]:00}";
            }
            else
            {
                try
                {
                    var parts = trainerId.Split('-');
                    if (parts.Length == 2 && int.TryParse(parts[1], out int fileCount))
                    {
                        if (!_yearlyTrainerCounters.ContainsKey(startYear) || fileCount > _yearlyTrainerCounters[startYear])
                        {
                            _yearlyTrainerCounters[startYear] = fileCount;
                        }
                    }
                }
                catch { }
            }

            var trainer = new Trainer(trainerId, name, specialization, hourlyRate, startYear);
            Trainers.Add(trainer);
            return trainer;
        }

        public void SeedTrainersIfEmpty()
        {
            if (Trainers.Count > 0) return;
            foreach (var (name, specialty, rate, year) in Trainer.SeedRoster)
                GetOrAddTrainer(name, specialty, rate, year);
        }

        private string NextSessionId()
        {
            _sessionCounter++;
            return $"S-{_sessionCounter:000000}";
        }

        public bool TryBookSession(Member member, Trainer trainer, DateTime date, int durationMinutes, SessionPriority priority, out string errorMessage)
        {
            errorMessage = null;
            try
            {
                var session = new TrainingSession(NextSessionId(), member, trainer, date, durationMinutes, "Scheduled", priority);
                member.Sessions.Add(session);
                Sessions.Add(session);
                return true;
            }
            catch (InvalidSessionDurationException ex)
            {
                errorMessage = ex.Message;
                return false;
            }
        }

        public bool TryCancelSession(string sessionId, out string message)
        {
            var session = Sessions.FirstOrDefault(s => s.SessionId.Equals(sessionId, StringComparison.OrdinalIgnoreCase));
            if (session == null)
            {
                message = $"No session found with ID '{sessionId}'.";
                return false;
            }
            if (session.Status == "Cancelled")
            {
                message = $"Session {session.SessionId} is already cancelled.";
                return false;
            }
            session.Status = "Cancelled";
            message = $"Session {session.SessionId} for {session.Member.Name} has been cancelled.";
            return true;
        }

        public void SaveAll() { SaveMembers(); SaveSessions(); }
        public void LoadAll() { LoadMembers(); LoadSessions(); }

        private void SaveMembers()
        {
            var lines = new List<string>();
            foreach (var member in Members)
            {
                var ms = member.Membership;
                string typeFields = ms switch
                {
                    StandardMembership s => $"{s.BaseRate}",
                    PremiumMembership p => $"{p.BaseRate}|{p.TrainingCreditValue}|{p.LoyaltyDiscount}",
                    StudentMembership st => $"{st.BaseRate}|{st.StudentId}",
                    _ => ""
                };
                lines.Add(string.Join("|", member.MemberId, member.Name, member.Contact, member.GenderIdentity, ms.TypeTag(), ms.MembershipId, ms.StartDate.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture), typeFields));
            }
            File.WriteAllLines(MembersFile, lines);
        }

        private void LoadMembers()
        {
            if (!File.Exists(MembersFile)) return;
            foreach (var line in File.ReadAllLines(MembersFile))
            {
                if (string.IsNullOrWhiteSpace(line)) continue;
                try
                {
                    var parts = line.Split('|');
                    string memberId = parts[0];
                    string name = parts[1];
                    string contact = parts[2];
                    
                    // Maintain smooth historical load safety layout checks
                    string gender = parts[3];
                    int skip = 0;
                    if (gender == "Standard" || gender == "Premium" || gender == "Student")
                    {
                        gender = "Not Specified";
                        skip = -1;
                    }

                    string type = parts[4 + skip];
                    string membershipId = parts[5 + skip];
                    DateTime startDate = DateTime.ParseExact(parts[6 + skip], "yyyy-MM-dd", CultureInfo.InvariantCulture);

                    Membership membership = type switch
                    {
                        "Standard" => new StandardMembership(membershipId, name, startDate, decimal.Parse(parts[7 + skip])),
                        "Premium" => new PremiumMembership(membershipId, name, startDate, decimal.Parse(parts[7 + skip]), decimal.Parse(parts[8 + skip]), decimal.Parse(parts[9 + skip])),
                        "Student" => new StudentMembership(membershipId, name, startDate, decimal.Parse(parts[7 + skip]), parts.Length > (8 + skip) ? parts[8 + skip] : ""),
                        _ => throw new FormatException($"Unknown type '{type}'")
                    };
                    Members.Add(new Member(memberId, name, contact, gender, membership));
                }
                catch { }
            }
        }

        private void SaveSessions()
        {
            var lines = Sessions.Select(s => string.Join("|", s.SessionId, s.Member.MemberId, s.Trainer.IdFallback(), s.Trainer.Name, s.Trainer.Specialization, s.Trainer.HourlyRate, s.Date.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture), s.DurationMinutes, s.Status, s.Priority, s.Trainer.StartYear));
            File.WriteAllLines(SessionsFile, lines);
        }

        private void LoadSessions()
        {
            if (!File.Exists(SessionsFile)) return;
            foreach (var line in File.ReadAllLines(SessionsFile))
            {
                if (string.IsNullOrWhiteSpace(line)) continue;
                try
                {
                    var parts = line.Split('|');
                    string sessionId = parts[0];
                    string memberId = parts[1];
                    
                    string trainerId = parts[2].Contains("-") ? parts[2] : null;
                    int offset = trainerId != null ? 0 : -1;

                    string trainerName = parts[3 + offset];
                    string specialization = parts[4 + offset];
                    decimal hourlyRate = decimal.Parse(parts[5 + offset]);
                    DateTime date = DateTime.ParseExact(parts[6 + offset], "yyyy-MM-dd", CultureInfo.InvariantCulture);
                    int duration = int.Parse(parts[7 + offset]);
                    string status = parts[8 + offset];
                    
                    SessionPriority priority = parts.Length > (9 + offset) 
                        ? (SessionPriority)Enum.Parse(typeof(SessionPriority), parts[9 + offset]) 
                        : SessionPriority.Normal;

                    int startYear = parts.Length > (10 + offset)
                        ? int.Parse(parts[10 + offset])
                        : 2023;

                    var member = Members.FirstOrDefault(m => m.MemberId == memberId);
                    if (member == null) continue;

                    var trainer = GetOrAddTrainer(trainerName, specialization, hourlyRate, startYear, trainerId);
                    var session = new TrainingSession(sessionId, member, trainer, date, duration, status, priority);
                    member.Sessions.Add(session);
                    Sessions.Add(session);

                    string digits = new string(sessionId.Where(char.IsDigit).ToArray());
                    if (int.TryParse(digits, out int numericId) && numericId > _sessionCounter) _sessionCounter = numericId;
                }
                catch { }
            }
        }
    }

